# ============================================================
# APP_ENV: 배포 환경 구분 (dev | prd)
#   dev → DEV_<LAYER>_DB_* 변수를 읽음
#   prd → PRD_<LAYER>_DB_* 변수를 읽음
#
# USE_MOCK=true 면 APP_ENV 에 관계없이 DB 미사용
# connectString 예: host:port/service  ex) 10.0.0.10:1521/XEPDB1
# ============================================================

APP_ENV=dev
# USE_MOCK=true

# ────────────────────────── DEV ──────────────────────────────

# --- CUBE ---
DEV_CUBE_DB_USER=
DEV_CUBE_DB_PASSWORD=
DEV_CUBE_DB_CONNECT_STRING=

# --- GAIA ---
DEV_GAIA_DB_USER=
DEV_GAIA_DB_PASSWORD=
DEV_GAIA_DB_CONNECT_STRING=

# --- MCP ---
DEV_MCP_DB_USER=
DEV_MCP_DB_PASSWORD=
DEV_MCP_DB_CONNECT_STRING=

# --- ONEOIS ---
DEV_ONEOIS_DB_USER=
DEV_ONEOIS_DB_PASSWORD=
DEV_ONEOIS_DB_CONNECT_STRING=

# --- LEGACY ---
DEV_LEGACY_DB_USER=
DEV_LEGACY_DB_PASSWORD=
DEV_LEGACY_DB_CONNECT_STRING=

# ────────────────────────── PRD ──────────────────────────────

# --- CUBE ---
PRD_CUBE_DB_USER=
PRD_CUBE_DB_PASSWORD=
PRD_CUBE_DB_CONNECT_STRING=

# --- GAIA ---
PRD_GAIA_DB_USER=
PRD_GAIA_DB_PASSWORD=
PRD_GAIA_DB_CONNECT_STRING=

# --- MCP ---
PRD_MCP_DB_USER=
PRD_MCP_DB_PASSWORD=
PRD_MCP_DB_CONNECT_STRING=

# --- ONEOIS ---
PRD_ONEOIS_DB_USER=
PRD_ONEOIS_DB_PASSWORD=
PRD_ONEOIS_DB_CONNECT_STRING=

# --- LEGACY ---
PRD_LEGACY_DB_USER=
PRD_LEGACY_DB_PASSWORD=
PRD_LEGACY_DB_CONNECT_STRING=
